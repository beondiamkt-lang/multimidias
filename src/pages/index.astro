---
import LandingLayout from '@/layouts/LandingLayout.astro';
import { Hero } from '@/components/hero';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import LetterGlitchBand from '@/components/patterns/LetterGlitchBand.astro';
import LetterGlitch from '@/components/effects/LetterGlitch.astro';
import StackMarquee from '@/components/landing/StackMarquee.astro';
import { getCollection } from 'astro:content';
import siteConfig from '@/config/site.config';

const projectItems = await getCollection('projects');
const featuredProjects = projectItems
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf();
  })
  .slice(0, 4);
---

<LandingLayout
  title="Multimidias SEO, AEO e GEO"
  description="Consultoria especializada em posicionamento orgânico no Google e IAs."
  image="/og-default.svg"
  includePersonSchema={true}
  includeProfessionalServiceSchema={true}
>
  <!-- Hero -->
  <section class="relative z-10 min-h-screen flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0" aria-hidden="true">
      <LetterGlitch outerVignette />
    </div>
    <div class="relative z-10 px-6 py-24 w-full flex items-center justify-center">
      <div class="mx-auto max-w-2xl rounded-2xl border border-white/10 bg-brand-900/85 px-6 py-10 sm:px-10 text-center shadow-xl backdrop-blur-md">
        <h1 class="font-display text-4xl md:text-6xl font-bold text-white mb-4 text-balance">
          Sites focados em SEO, AEO e GEO
        </h1>
        <p class="text-lg text-white/70 mb-8 text-balance">
          Eu projeto e desenvolvo sites novos do zero — cada projeto, do início ao fim, feito por mim — 100% focados em posicionamento orgânico em buscadores e LLMs.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <Button size="lg" href="/contato" class="hero-btn-brand">
            Iniciar um projeto
            <Icon name="arrow-right" size="sm" />
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>Serviços</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            O que eu faço
          </h2>
        </div>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto">
          Do conceito ao lançamento.
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-3">
        <!-- Imersão Cliente -->
        <Card hover href="/servicos" class="group flex flex-col" data-reveal>
          <div class="flex items-start gap-4 sm:flex-col sm:items-center sm:gap-3 sm:text-center lg:flex-row lg:items-start lg:gap-4 lg:text-left">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="search" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Imersão Cliente</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Antes de escrever uma linha de código, estudo a fundo o seu negócio, mercado e concorrentes. Tudo que construo é baseado em dados reais, não em suposições.
              </p>
            </div>
          </div>
        </Card>

        <!-- Inteligência de Mercado -->
        <Card hover href="/servicos" class="group flex flex-col" data-reveal data-reveal-delay="1">
          <div class="flex items-start gap-4 sm:flex-col sm:items-center sm:gap-3 sm:text-center lg:flex-row lg:items-start lg:gap-4 lg:text-left">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="bar-chart-2" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Inteligência de Mercado</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Mapeio os termos mais buscados no Google, nas redes sociais e os prompts usados em IAs sobre o seu mercado. Você descobre exatamente o que seu público quer — antes da concorrência.
              </p>
            </div>
          </div>
        </Card>

        <!-- Design Web -->
        <Card hover href="/servicos" class="group flex flex-col" data-reveal data-reveal-delay="2">
          <div class="flex items-start gap-4 sm:flex-col sm:items-center sm:gap-3 sm:text-center lg:flex-row lg:items-start lg:gap-4 lg:text-left">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="layout" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Design Web</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Layouts pensados que colocam seu conteúdo em primeiro lugar. Projetados para clareza, equilíbrio e a forma como as pessoas realmente leem na web.
              </p>
            </div>
          </div>
        </Card>

        <!-- SEO & Performance -->
        <Card hover href="/servicos" class="group flex flex-col" data-reveal data-reveal-delay="0">
          <div class="flex items-start gap-4 sm:flex-col sm:items-center sm:gap-3 sm:text-center lg:flex-row lg:items-start lg:gap-4 lg:text-left">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
